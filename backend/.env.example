# Server
NODE_ENV=development
PORT=5000

# Database (AWS RDS PostgreSQL)
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_BUCKET_NAME=your-s3-bucket-name

# Ranking Collection
RANKING_AUTO_ENABLED=true

# PROXY_MODE: none (프록시 없음) / residential (Playwright+프록시) / site_unblocker (Decodo Site Unblocker HTTP)
PROXY_MODE=site_unblocker

# Residential 모드 (PROXY_MODE=residential)
PROXY_SERVER=http://kr.decodo.com:10000
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password

# Site Unblocker 모드 (PROXY_MODE=site_unblocker)
SITE_UNBLOCKER_HOST=unblock.decodo.com:60000
SITE_UNBLOCKER_USER=your-unblocker-username
SITE_UNBLOCKER_PASS=your-unblocker-password

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/gif,image/webp

# Admin AI 챗 (text-to-SQL)
AI_CHAT_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-opus-4-8
# 접근 허용 계정: 미설정/빈값 → 모든 admin (test 환경), 'masterkangwoo' → 해당 계정만 (운영 환경)
# 운영 .env 에서만 AI_CHAT_ALLOWED_USERS=masterkangwoo 로 설정
AI_CHAT_ALLOWED_USERS=
# 읽기전용 DB 계정 (SELECT 권한만 부여한 Postgres 역할)
# CREATE ROLE ai_readonly WITH LOGIN PASSWORD '...'; GRANT SELECT ON ALL TABLES IN SCHEMA public TO ai_readonly; ...
DB_READONLY_USER=ai_readonly
DB_READONLY_PASSWORD=your_readonly_password
