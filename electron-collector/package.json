{
  "name": "ranking-collector",
  "version": "1.0.0",
  "description": "올리브영 BEST 랭킹 수집기",
  "main": "src/main/index.js",
  "author": "kingnight7",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5174 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:installer": "electron-builder --win",
    "build": "npm run build:renderer && npm run build:installer"
  },
  "dependencies": {
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "cheerio": "1.0.0-rc.12",
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "pg": "^8.11.3",
    "playwright": "1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sequelize": "^6.35.2",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kwad.ranking-collector",
    "productName": "RankingCollector",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist-renderer/**/*",
      "package.json",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "../backend/src/services/rankingTracker",
        "to": "rankingTracker"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "RankingCollector-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "올리브영 랭킹 수집기"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*"
    ]
  }
}
