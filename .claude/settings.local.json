      "Bash(node -e:*)",
      "Bash(curl:*)",
      "Bash(npm install:*)",
      "Bash(npm start)",
      "Bash(dir:*)",
      "Bash(taskkill:*)",
      "Bash(if not exist \"c:\\Users\\achil\\Desktop\\purchaseweb\\backend\\src\\middleware\" mkdir \"c:\\Users\\achil\\Desktop\\purchaseweb\\backend\\src\\middleware\")",
      "Bash(npm run db:seed:*)",
      "Bash(npm run build:*)",
      "Bash(make deploy:*)",
      "Bash(ssh:*)",
